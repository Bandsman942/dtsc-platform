generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CLIENT
  SUPPORT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum MessageRole {
  user
  assistant
  system
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SubscriptionStatus {
  ACTIVE
  PENDING_PAYMENT
  PAST_DUE
  CANCELED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  ACCEPTED
  PAID
  FAILED
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELED
}

enum DocumentStatus {
  PROCESSING
  READY
  FAILED
}

model User {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  passwordHash  String
  role          UserRole        @default(CLIENT)
  companyName   String?
  phone         String?
  jobTitle      String?
  bio           String?
  location      String?
  website       String?
  avatarUrl     String?
  avatarStoragePath String?
  publicProfileConsent Boolean @default(false)
  preferredModel String?
  notifySupportEnabled Boolean @default(true)
  notifyUsageEnabled   Boolean @default(true)
  notifyBroadcastEnabled Boolean @default(true)
  pushNotificationsEnabled Boolean @default(false)
  interfaceDensity String @default("COMFORTABLE")
  startPage String @default("/dashboard")
  locale String @default("fr")
  timezone String @default("Africa/Kinshasa")
  dateFormat String @default("FR")
  callSoundsEnabled Boolean @default(true)
  callNotificationsEnabled Boolean @default(true)
  floatingCallAlertsEnabled Boolean @default(true)
  participantEventAlertsEnabled Boolean @default(true)
  callAlertSoundEnabled Boolean @default(true)
  incomingCallBannerEnabled Boolean @default(true)
  connectionIssueSoundsEnabled Boolean @default(true)
  startMutedByDefault Boolean @default(false)
  startCameraOffByDefault Boolean @default(true)
  callSoundVolume Int @default(45)
  callAlertDisplayDuration Int @default(6000)
  preferredAudioInputId String?
  preferredVideoInputId String?
  preferredAudioOutputId String?
  emailDigestFrequency String @default("WEEKLY")
  chatResponseStyle String @default("PROFESSIONAL")
  chatResponseLength String @default("BALANCED")
  lastSeenAt    DateTime?
  status        UserStatus      @default(ACTIVE)
  dailyMessageLimit Int         @default(30)
  dailyTokenLimit   Int         @default(100000)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  conversations Conversation[]
  messages      Message[]
  usageLogs     UsageLog[]
  supportTickets SupportTicket[]
  ticketMessages TicketMessage[]
  notifications Notification[]
  announcements Announcement[]
  announcementComments AnnouncementComment[]
  announcementReactions AnnouncementReaction[]
  auditLogs     AuditLog[]
  subscriptions Subscription[]
  payments      Payment[]
  invoices      Invoice[]
  documents           KnowledgeDocument[]
  publicPublications  PublicPublication[]
  publicPublicationComments PublicPublicationComment[]
  publicPublicationReactions PublicPublicationReaction[]
  companyProfiles     CompanyProfile[]
  companyActivities   CompanyActivity[]
  pushSubscriptions    PushSubscription[]
  conversationProjects ConversationProject[]
  hrcfoEmployee        HrcfoEmployee? @relation("EmployeeUser")
  managedHrcfoEmployees HrcfoEmployee[] @relation("EmployeeManager")
  cooComments          CooComment[]
  cooCommentMentions   CooCommentMention[]
  ownedCollaborationGroups CollaborationGroup[] @relation("CollaborationGroupOwner")
  collaborationGroupMembers CollaborationGroupMember[]
  sentCollaborationInvitations CollaborationGroupInvitation[] @relation("CollaborationInvitationSender")
  receivedCollaborationInvitations CollaborationGroupInvitation[] @relation("CollaborationInvitationReceiver")
  collaborationGroupMessages CollaborationGroupMessage[]
  collaborationGroupMessageReads CollaborationGroupMessageRead[]
  collaborationMessageMentions CollaborationMessageMention[]
  sharedConversationSnapshots CollaborationSharedConversation[] @relation("SharedConversationSharer")
  collaborationAuditLogs CollaborationGroupAuditLog[]
  announcementSharesSent AnnouncementShare[] @relation("AnnouncementShareSender")
  announcementSharesReceived AnnouncementShare[] @relation("AnnouncementShareRecipient")
  announcementReports AnnouncementReport[]
  organizationMemberships OrganizationMember[]
  organizationAdminGrants OrganizationAdminGrant[] @relation("OrganizationAdminGrantUser")
  grantedOrganizationAdmins OrganizationAdminGrant[] @relation("OrganizationAdminGrantDtscUser")
  createdOrganizations Organization[] @relation("OrganizationCreatedByDtsc")
  updatedOrganizationSubscriptions OrganizationSubscription[] @relation("OrganizationSubscriptionUpdatedBy")
  createdOrganizationSubscriptions OrganizationSubscription[] @relation("OrganizationSubscriptionCreatedBy")
  organizationBillingRecords BillingRecord[]
  enterpriseActivityRequests EnterpriseActivityRequest[]
  createdEnterpriseSectorRecords EnterpriseSectorRecord[] @relation("EnterpriseSectorRecordCreatedBy")
  updatedEnterpriseSectorRecords EnterpriseSectorRecord[] @relation("EnterpriseSectorRecordUpdatedBy")
  assignedEnterpriseSectorRecords EnterpriseSectorRecord[] @relation("EnterpriseSectorRecordAssignedTo")

  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@index([lastSeenAt])
}

model BillingPlan {
  id                String   @id
  name              String
  slug              String   @unique
  description       String
  priceUsd          Decimal  @db.Decimal(10, 2)
  dailyMessageLimit Int
  dailyTokenLimit   Int
  maxDocuments      Int      @default(0)
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  subscriptions     Subscription[]
  organizationSubscriptions OrganizationSubscription[]
  invoices          Invoice[]

  @@index([isActive, sortOrder])
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  planId             String
  status             SubscriptionStatus @default(PENDING_PAYMENT)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan               BillingPlan        @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments           Payment[]
  invoices           Invoice[]

  @@index([userId, status])
  @@index([planId])
  @@index([currentPeriodEnd])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  subscriptionId    String?
  provider          String        @default("MAISHAPAY")
  reference         String        @unique
  providerReference String?
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("USD")
  status            PaymentStatus @default(PENDING)
  checkoutPayload   Json?
  callbackPayload   Json?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice           Invoice?

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([providerReference])
}

model Invoice {
  id             String        @id @default(cuid())
  number         String        @unique
  userId         String
  planId         String?
  subscriptionId String?
  paymentId      String?       @unique
  planName       String
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("USD")
  status         InvoiceStatus @default(ISSUED)
  issuedAt       DateTime      @default(now())
  dueAt          DateTime?
  paidAt         DateTime?
  emailSentAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           BillingPlan?  @relation(fields: [planId], references: [id], onDelete: SetNull)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payment        Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  hrcfoTransactionId String?   @unique
  hrcfoTransaction   HrcfoExpense? @relation(fields: [hrcfoTransactionId], references: [id], onDelete: SetNull)

  @@index([userId, issuedAt])
  @@index([status, issuedAt])
}

model KnowledgeDocument {
  id            String         @id @default(cuid())
  userId        String
  organizationId String?
  title         String
  fileName      String
  mimeType      String
  sizeBytes     Int
  storageBucket String?
  storagePath   String?
  status        DocumentStatus @default(PROCESSING)
  extractedText String?
  errorMessage  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  chunks        KnowledgeChunk[]

  @@index([userId, organizationId, status, createdAt])
  @@index([storageBucket, storagePath])
  @@index([createdAt])
}

model KnowledgeChunk {
  id         String            @id @default(cuid())
  documentId String
  userId     String
  organizationId String?
  content    String
  tokenHint  Int               @default(0)
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime          @default(now())
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId, organizationId, createdAt])
}

model CompanyProfile {
  id                String   @id @default(cuid())
  userId            String
  organizationId    String?
  organizationName  String
  legalForm         String?
  sector            String?
  sizeRange         String?
  country           String?
  city              String?
  website           String?
  description       String?
  mission           String?
  productsServices  String?
  customers         String?
  markets           String?
  competitors       String?
  processes         String?
  tools             String?
  dataSystems       String?
  compliance        String?
  challenges        String?
  goals             String?
  kpis              String?
  userPosition      String?
  department        String?
  responsibilities  String?
  decisionRole      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([userId, organizationId])
  @@index([sector])
  @@index([updatedAt])
  @@index([userId, organizationId, updatedAt])
}

model CompanyActivity {
  id          String   @id @default(cuid())
  userId      String
  organizationId String?
  title       String
  description String
  frequency   String?
  priority    String   @default("MEDIUM")
  tools       String?
  dataInputs  String?
  dataOutputs String?
  painPoints  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId, organizationId, priority, updatedAt])
}

model PendingRegistration {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  companyName  String?
  phone        String?
  role         UserRole @default(CLIENT)
  otpHash      String
  attempts     Int      @default(0)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email, expiresAt])
  @@index([expiresAt])
}

model Conversation {
  id        String     @id @default(cuid())
  userId    String
  organizationId String?
  title     String     @default("Nouvelle conversation")
  projectName String?
  projectId String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  project   ConversationProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages  Message[]
  usageLogs UsageLog[]
  collaborationMessages CollaborationGroupMessage[]
  sharedConversationSnapshots CollaborationSharedConversation[]

  @@index([userId, organizationId, updatedAt])
  @@index([userId, organizationId, projectName, updatedAt])
  @@index([userId, organizationId, projectId, updatedAt])
}

model ConversationProject {
  id        String   @id @default(cuid())
  userId    String
  organizationId String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  conversations Conversation[]

  @@unique([userId, organizationId, name])
  @@index([userId, organizationId, updatedAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh     String
  auth       String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  userId         String?
  organizationId String?
  role           MessageRole
  content        String
  model          String?
  tokensUsed     Int?
  feedbackValue  Int?
  feedbackUpdatedAt DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([userId, organizationId])
}

model UsageLog {
  id             String       @id @default(cuid())
  userId         String
  organizationId String?
  conversationId String?
  model          String
  inputTokens    Int          @default(0)
  outputTokens   Int          @default(0)
  totalTokens    Int          @default(0)
  estimatedCost  Decimal      @default(0) @db.Decimal(10, 6)
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId, organizationId, createdAt])
  @@index([conversationId])
}

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String?  @unique
  logoUrl       String?
  ownerUserId   String?
  status        String   @default("DRAFT")
  organizationType String @default("CLIENT")
  sector        String?
  sectorId      String?
  sectorCode    String?
  industry      String?
  country       String?
  city          String?
  timezone      String   @default("Africa/Kinshasa")
  settingsJson  Json?
  brandingJson  Json?
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  notes         String?
  createdByDtscUserId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  businessSector BusinessSector? @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  createdByDtsc User? @relation("OrganizationCreatedByDtsc", fields: [createdByDtscUserId], references: [id], onDelete: SetNull)
  members       OrganizationMember[]
  adminGrants   OrganizationAdminGrant[]
  subscriptions OrganizationSubscription[]
  billingRecords BillingRecord[]
  knowledgeDocuments KnowledgeDocument[]
  companyProfiles CompanyProfile[]
  companyActivities CompanyActivity[]
  conversations Conversation[]
  conversationProjects ConversationProject[]
  notifications Notification[]
  supportTickets SupportTicket[]
  announcements Announcement[] @relation("AnnouncementOrganization")
  authoredAnnouncements Announcement[] @relation("AnnouncementAuthorOrganization")
  collaborationGroups CollaborationGroup[]
  enterpriseModules EnterpriseModule[]
  enterpriseAdminSections EnterpriseAdminSection[]
  enterprisePositions EnterprisePosition[]
  enterpriseDepartments EnterpriseDepartment[]
  enterpriseActivityBlocks EnterpriseActivityBlock[]
  enterpriseWorkflows EnterpriseWorkflow[]
  enterpriseActivityRequests EnterpriseActivityRequest[]
  enterpriseSectorRecords EnterpriseSectorRecord[]

  @@index([status, organizationType])
  @@index([sectorId])
  @@index([sectorCode])
  @@index([createdByDtscUserId])
}

model BusinessSector {
  id                String   @id
  code              String   @unique
  labelFr           String
  labelEn           String
  descriptionFr     String?
  descriptionEn     String?
  isicReferenceCode String?
  icon              String?
  color             String?
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  organizations     Organization[]
  templates         SectorTemplate[]
  enterpriseModules EnterpriseModule[]
  enterprisePositions EnterprisePosition[]
  enterpriseActivityBlocks EnterpriseActivityBlock[]

  @@index([isActive, sortOrder])
  @@index([code])
}

model SectorTemplate {
  id             String   @id
  sectorId       String
  version        Int      @default(1)
  label          String
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  sector         BusinessSector @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  modules        SectorTemplateModule[]
  positions      SectorTemplatePosition[]
  departments    SectorTemplateDepartment[]
  activityBlocks SectorTemplateActivityBlock[]
  workflows      SectorTemplateWorkflow[]

  @@unique([sectorId, version])
  @@index([sectorId, isActive])
}

model SectorTemplateModule {
  id                String   @id
  templateId        String
  moduleCode        String
  labelFr           String
  labelEn           String
  descriptionFr     String?
  descriptionEn     String?
  moduleCategory    String
  icon              String?
  sortOrder         Int      @default(0)
  defaultEnabled    Boolean  @default(true)
  requiresPlanLevel String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  template          SectorTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  enterpriseModules EnterpriseModule[]
  enterpriseAdminSections EnterpriseAdminSection[]

  @@unique([templateId, moduleCode])
  @@index([moduleCode])
}

model SectorTemplatePosition {
  id                     String   @id
  templateId             String
  positionCode           String
  labelFr                String
  labelEn                String
  departmentCode         String?
  hierarchyLevel         Int      @default(50)
  descriptionFr          String?
  descriptionEn          String?
  defaultPermissionsJson Json?
  isKeyPosition          Boolean  @default(false)
  sortOrder              Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  template               SectorTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  enterprisePositions    EnterprisePosition[]

  @@unique([templateId, positionCode])
  @@index([positionCode])
}

model SectorTemplateDepartment {
  id              String   @id
  templateId      String
  departmentCode  String
  labelFr         String
  labelEn         String
  descriptionFr   String?
  descriptionEn   String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  template        SectorTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  enterpriseDepartments EnterpriseDepartment[]

  @@unique([templateId, departmentCode])
  @@index([departmentCode])
}

model SectorTemplateActivityBlock {
  id               String   @id
  templateId       String
  blockCode        String
  labelFr          String
  labelEn          String
  descriptionFr    String?
  descriptionEn    String?
  icon             String?
  sortOrder        Int      @default(0)
  defaultEnabled   Boolean  @default(true)
  targetModuleCode String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  template         SectorTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  enterpriseActivityBlocks EnterpriseActivityBlock[]

  @@unique([templateId, blockCode])
  @@index([blockCode])
}

model SectorTemplateWorkflow {
  id             String   @id
  templateId     String
  workflowCode   String
  labelFr        String
  labelEn        String
  descriptionFr  String?
  descriptionEn  String?
  stepsJson      Json?
  defaultEnabled Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  template       SectorTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  enterpriseWorkflows EnterpriseWorkflow[]

  @@unique([templateId, workflowCode])
  @@index([workflowCode])
}

model EnterpriseModule {
  id                String   @id @default(cuid())
  organizationId    String
  sectorId          String?
  moduleCode        String
  labelFr           String
  labelEn           String
  descriptionFr     String?
  descriptionEn     String?
  moduleCategory    String
  icon              String?
  isEnabled         Boolean  @default(true)
  isCore            Boolean  @default(false)
  sourceTemplateId  String?
  requiresPlanLevel String?
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sector            BusinessSector? @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  sourceTemplate    SectorTemplateModule? @relation(fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  adminSections     EnterpriseAdminSection[]

  @@unique([organizationId, moduleCode])
  @@index([organizationId])
  @@index([sectorId])
  @@index([moduleCode])
  @@index([isEnabled])
}

model EnterpriseAdminSection {
  id                 String   @id @default(cuid())
  organizationId     String
  moduleId           String
  sectionCode        String
  labelFr            String
  labelEn            String
  descriptionFr      String?
  descriptionEn      String?
  icon               String?
  isEnabled          Boolean  @default(true)
  requiredPermission String?
  sortOrder          Int      @default(0)
  sourceTemplateId   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  module             EnterpriseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  sourceTemplate     SectorTemplateModule? @relation(fields: [sourceTemplateId], references: [id], onDelete: SetNull)

  @@unique([organizationId, sectionCode])
  @@index([organizationId])
  @@index([moduleId])
  @@index([sectionCode])
}

model EnterprisePosition {
  id                     String   @id @default(cuid())
  organizationId         String
  sectorId               String?
  positionCode           String
  labelFr                String
  labelEn                String
  departmentId           String?
  hierarchyLevel         Int      @default(50)
  descriptionFr          String?
  descriptionEn          String?
  permissionsJson        Json?
  isActive               Boolean  @default(true)
  isKeyPosition          Boolean  @default(false)
  sourceTemplateId       String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sector                 BusinessSector? @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  department             EnterpriseDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  sourceTemplate         SectorTemplatePosition? @relation(fields: [sourceTemplateId], references: [id], onDelete: SetNull)

  @@unique([organizationId, positionCode])
  @@index([organizationId])
  @@index([sectorId])
  @@index([positionCode])
  @@index([departmentId])
}

model EnterpriseDepartment {
  id               String   @id @default(cuid())
  organizationId   String
  departmentCode   String
  labelFr          String
  labelEn          String
  descriptionFr    String?
  descriptionEn    String?
  responsibleUserId String?
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  sourceTemplateId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceTemplate   SectorTemplateDepartment? @relation(fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  positions        EnterprisePosition[]

  @@unique([organizationId, departmentCode])
  @@index([organizationId])
  @@index([departmentCode])
  @@index([responsibleUserId])
}

model EnterpriseActivityBlock {
  id                 String   @id @default(cuid())
  organizationId     String
  sectorId           String?
  blockCode          String
  labelFr            String
  labelEn            String
  descriptionFr      String?
  descriptionEn      String?
  icon               String?
  targetModuleCode   String?
  isEnabled          Boolean  @default(true)
  requiredPermission String?
  sortOrder          Int      @default(0)
  sourceTemplateId   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sector             BusinessSector? @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  sourceTemplate     SectorTemplateActivityBlock? @relation(fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  requests           EnterpriseActivityRequest[]

  @@unique([organizationId, blockCode])
  @@index([organizationId])
  @@index([sectorId])
  @@index([blockCode])
}

model EnterpriseWorkflow {
  id               String   @id @default(cuid())
  organizationId   String
  workflowCode     String
  labelFr          String
  labelEn          String
  descriptionFr    String?
  descriptionEn    String?
  stepsJson        Json?
  isEnabled        Boolean  @default(true)
  sourceTemplateId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
