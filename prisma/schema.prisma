generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CLIENT
  SUPPORT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum MessageRole {
  user
  assistant
  system
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SubscriptionStatus {
  ACTIVE
  PENDING_PAYMENT
  PAST_DUE
  CANCELED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  ACCEPTED
  PAID
  FAILED
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELED
}

enum DocumentStatus {
  PROCESSING
  READY
  FAILED
}

model User {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  passwordHash  String
  role          UserRole        @default(CLIENT)
  companyName   String?
  phone         String?
  jobTitle      String?
  bio           String?
  location      String?
  website       String?
  avatarUrl     String?
  avatarStoragePath String?
  publicProfileConsent Boolean @default(false)
  status        UserStatus      @default(ACTIVE)
  dailyMessageLimit Int         @default(30)
  dailyTokenLimit   Int         @default(100000)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  conversations Conversation[]
  messages      Message[]
  usageLogs     UsageLog[]
  supportTickets SupportTicket[]
  ticketMessages TicketMessage[]
  notifications Notification[]
  announcements Announcement[]
  announcementComments AnnouncementComment[]
  announcementReactions AnnouncementReaction[]
  auditLogs     AuditLog[]
  subscriptions Subscription[]
  payments      Payment[]
  invoices      Invoice[]
  documents           KnowledgeDocument[]
  publicPublications  PublicPublication[]
  publicPublicationComments PublicPublicationComment[]
  publicPublicationReactions PublicPublicationReaction[]
  companyProfile      CompanyProfile?
  companyActivities   CompanyActivity[]

  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model BillingPlan {
  id                String   @id
  name              String
  slug              String   @unique
  description       String
  priceUsd          Decimal  @db.Decimal(10, 2)
  dailyMessageLimit Int
  dailyTokenLimit   Int
  maxDocuments      Int      @default(0)
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  subscriptions     Subscription[]
  invoices          Invoice[]

  @@index([isActive, sortOrder])
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  planId             String
  status             SubscriptionStatus @default(PENDING_PAYMENT)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan               BillingPlan        @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments           Payment[]
  invoices           Invoice[]

  @@index([userId, status])
  @@index([planId])
  @@index([currentPeriodEnd])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  subscriptionId    String?
  provider          String        @default("MAISHAPAY")
  reference         String        @unique
  providerReference String?
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("USD")
  status            PaymentStatus @default(PENDING)
  checkoutPayload   Json?
  callbackPayload   Json?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice           Invoice?

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([providerReference])
}

model Invoice {
  id             String        @id @default(cuid())
  number         String        @unique
  userId         String
  planId         String?
  subscriptionId String?
  paymentId      String?       @unique
  planName       String
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("USD")
  status         InvoiceStatus @default(ISSUED)
  issuedAt       DateTime      @default(now())
  dueAt          DateTime?
  paidAt         DateTime?
  emailSentAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           BillingPlan?  @relation(fields: [planId], references: [id], onDelete: SetNull)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payment        Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([userId, issuedAt])
  @@index([status, issuedAt])
}

model KnowledgeDocument {
  id            String         @id @default(cuid())
  userId        String
  title         String
  fileName      String
  mimeType      String
  sizeBytes     Int
  storageBucket String?
  storagePath   String?
  status        DocumentStatus @default(PROCESSING)
  extractedText String?
  errorMessage  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks        KnowledgeChunk[]

  @@index([userId, status, createdAt])
  @@index([storageBucket, storagePath])
  @@index([createdAt])
}

model KnowledgeChunk {
  id         String            @id @default(cuid())
  documentId String
  userId     String
  content    String
  tokenHint  Int               @default(0)
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime          @default(now())
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId, createdAt])
}

model CompanyProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  organizationName  String
  legalForm         String?
  sector            String?
  sizeRange         String?
  country           String?
  city              String?
  website           String?
  description       String?
  mission           String?
  productsServices  String?
  customers         String?
  markets           String?
  competitors       String?
  processes         String?
  tools             String?
  dataSystems       String?
  compliance        String?
  challenges        String?
  goals             String?
  kpis              String?
  userPosition      String?
  department        String?
  responsibilities  String?
  decisionRole      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sector])
  @@index([updatedAt])
}

model CompanyActivity {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  frequency   String?
  priority    String   @default("MEDIUM")
  tools       String?
  dataInputs  String?
  dataOutputs String?
  painPoints  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, priority, updatedAt])
}

model PendingRegistration {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  companyName  String?
  phone        String?
  role         UserRole @default(CLIENT)
  otpHash      String
  attempts     Int      @default(0)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email, expiresAt])
  @@index([expiresAt])
}

model Conversation {
  id        String     @id @default(cuid())
  userId    String
  title     String     @default("Nouvelle conversation")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  usageLogs UsageLog[]

  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  userId         String?
  role           MessageRole
  content        String
  model          String?
  tokensUsed     Int?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([userId])
}

model UsageLog {
  id             String       @id @default(cuid())
  userId         String
  conversationId String?
  model          String
  inputTokens    Int          @default(0)
  outputTokens   Int          @default(0)
  totalTokens    Int          @default(0)
  estimatedCost  Decimal      @default(0) @db.Decimal(10, 6)
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([conversationId])
}

model Organization {
  id            String   @id @default(cuid())
  name          String
  sector        String?
  contactPerson String?
  email         String?
  phone         String?
  createdAt     DateTime @default(now())
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  companyName String?
  interest    String?
  source      String   @default("landing")
  consent     Boolean  @default(true)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
}

model ContactMessage {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  companyName String?
  subject     String
  message     String
  source      String   @default("landing")
  createdAt   DateTime @default(now())

  @@index([email, createdAt])
  @@index([source, createdAt])
}

model SupportTicket {
  id          String         @id @default(cuid())
  userId      String
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  resolution  String?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    TicketMessage[]

  @@index([userId, status])
  @@index([priority, createdAt])
}

model TicketMessage {
  id        String        @id @default(cuid())
  ticketId  String
  userId    String
  content   String
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([userId])
}

model SiteVisit {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@index([createdAt])
}

model PublicPublication {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  category    String   @default("RESSOURCE")
  excerpt     String
  content     String
  coverLabel  String?
  published   Boolean  @default(false)
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  comments    PublicPublicationComment[]
  reactions   PublicPublicationReaction[]

  @@index([category, published, createdAt])
  @@index([authorId])
}

model PublicPublicationComment {
  id            String   @id @default(cuid())
  publicationId String
  userId        String
  parentId      String?
  content       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  publication   PublicPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        PublicPublicationComment? @relation("PublicPublicationCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       PublicPublicationComment[] @relation("PublicPublicationCommentReplies")

  @@index([publicationId, createdAt])
  @@index([userId])
  @@index([parentId])
}

model PublicPublicationReaction {
  id            String   @id @default(cuid())
  publicationId String
  userId        String
  value         Int
  createdAt     DateTime @default(now())
  publication   PublicPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([publicationId, userId])
  @@index([userId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String    @default("INFO")
  targetUrl String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model Announcement {
  id        String                 @id @default(cuid())
  authorId  String
  title     String
  content   String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  author    User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  AnnouncementComment[]
  reactions AnnouncementReaction[]

  @@index([createdAt])
  @@index([authorId])
}

model AnnouncementComment {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  parentId       String?
  content        String
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent         AnnouncementComment? @relation("AnnouncementCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies        AnnouncementComment[] @relation("AnnouncementCommentReplies")

  @@index([announcementId, createdAt])
  @@index([userId])
  @@index([parentId])
}

model AnnouncementReaction {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  value          Int
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
}

model AppSetting {
  id                       String   @id @default("global")
  defaultDailyMessageLimit Int      @default(30)
  defaultDailyTokenLimit   Int      @default(100000)
  chatbotEnabled           Boolean  @default(true)
  maintenanceMode          Boolean  @default(false)
  supportAutoCloseDays     Int      @default(7)
  allowClientAnnouncements Boolean  @default(false)
  announcementEditWindowMinutes Int @default(30)
  commentEditWindowMinutes      Int @default(15)
  notificationRetentionDays     Int @default(60)
  signUpOtpEnabled              Boolean @default(true)
  signUpOtpExpirationMinutes    Int @default(10)
  adminRoleAccess               Json    @default("{}")
  updatedAt                DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entity, entityId])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  eventType   String
  status      String   @default("RECEIVED")
  payload     Json
  attempts    Int      @default(0)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([provider, eventType, createdAt])
  @@index([status, createdAt])
}

model ApiLog {
  id          String   @id @default(cuid())
  method      String
  path        String
  statusCode  Int
  userId      String?
  durationMs  Int?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([path, createdAt])
  @@index([statusCode, createdAt])
  @@index([userId, createdAt])
}
