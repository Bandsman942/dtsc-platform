generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CLIENT
  SUPPORT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum MessageRole {
  user
  assistant
  system
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  passwordHash  String
  role          UserRole        @default(CLIENT)
  companyName   String?
  phone         String?
  status        UserStatus      @default(ACTIVE)
  dailyMessageLimit Int         @default(30)
  dailyTokenLimit   Int         @default(100000)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  conversations Conversation[]
  messages      Message[]
  usageLogs     UsageLog[]
  supportTickets SupportTicket[]
  ticketMessages TicketMessage[]
  notifications Notification[]
  announcements Announcement[]
  announcementComments AnnouncementComment[]
  announcementReactions AnnouncementReaction[]

  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model Conversation {
  id        String     @id @default(cuid())
  userId    String
  title     String     @default("Nouvelle conversation")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  usageLogs UsageLog[]

  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  userId         String?
  role           MessageRole
  content        String
  model          String?
  tokensUsed     Int?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([userId])
}

model UsageLog {
  id             String       @id @default(cuid())
  userId         String
  conversationId String?
  model          String
  inputTokens    Int          @default(0)
  outputTokens   Int          @default(0)
  totalTokens    Int          @default(0)
  estimatedCost  Decimal      @default(0) @db.Decimal(10, 6)
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([conversationId])
}

model Organization {
  id            String   @id @default(cuid())
  name          String
  sector        String?
  contactPerson String?
  email         String?
  phone         String?
  createdAt     DateTime @default(now())
}

model SupportTicket {
  id          String         @id @default(cuid())
  userId      String
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  resolution  String?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    TicketMessage[]

  @@index([userId, status])
  @@index([priority, createdAt])
}

model TicketMessage {
  id        String        @id @default(cuid())
  ticketId  String
  userId    String
  content   String
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([userId])
}

model SiteVisit {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@index([createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String    @default("INFO")
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model Announcement {
  id        String                 @id @default(cuid())
  authorId  String
  title     String
  content   String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  author    User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  AnnouncementComment[]
  reactions AnnouncementReaction[]

  @@index([createdAt])
  @@index([authorId])
}

model AnnouncementComment {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  content        String
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([announcementId, createdAt])
  @@index([userId])
}

model AnnouncementReaction {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  value          Int
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
}

model AppSetting {
  id                       String   @id @default("global")
  defaultDailyMessageLimit Int      @default(30)
  defaultDailyTokenLimit   Int      @default(100000)
  chatbotEnabled           Boolean  @default(true)
  maintenanceMode          Boolean  @default(false)
  supportAutoCloseDays     Int      @default(7)
  allowClientAnnouncements Boolean  @default(false)
  updatedAt                DateTime @updatedAt
}
