generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CLIENT
  SUPPORT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum MessageRole {
  user
  assistant
  system
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SubscriptionStatus {
  ACTIVE
  PENDING_PAYMENT
  PAST_DUE
  CANCELED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  ACCEPTED
  PAID
  FAILED
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELED
}

enum DocumentStatus {
  PROCESSING
  READY
  FAILED
}

model User {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  passwordHash  String
  role          UserRole        @default(CLIENT)
  companyName   String?
  phone         String?
  jobTitle      String?
  bio           String?
  location      String?
  website       String?
  avatarUrl     String?
  avatarStoragePath String?
  publicProfileConsent Boolean @default(false)
  preferredModel String?
  notifySupportEnabled Boolean @default(true)
  notifyUsageEnabled   Boolean @default(true)
  notifyBroadcastEnabled Boolean @default(true)
  pushNotificationsEnabled Boolean @default(false)
  interfaceDensity String @default("COMFORTABLE")
  startPage String @default("/dashboard")
  locale String @default("fr")
  timezone String @default("Africa/Kinshasa")
  dateFormat String @default("FR")
  emailDigestFrequency String @default("WEEKLY")
  chatResponseStyle String @default("PROFESSIONAL")
  chatResponseLength String @default("BALANCED")
  status        UserStatus      @default(ACTIVE)
  dailyMessageLimit Int         @default(30)
  dailyTokenLimit   Int         @default(100000)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  conversations Conversation[]
  messages      Message[]
  usageLogs     UsageLog[]
  supportTickets SupportTicket[]
  ticketMessages TicketMessage[]
  notifications Notification[]
  announcements Announcement[]
  announcementComments AnnouncementComment[]
  announcementReactions AnnouncementReaction[]
  auditLogs     AuditLog[]
  subscriptions Subscription[]
  payments      Payment[]
  invoices      Invoice[]
  documents           KnowledgeDocument[]
  publicPublications  PublicPublication[]
  publicPublicationComments PublicPublicationComment[]
  publicPublicationReactions PublicPublicationReaction[]
  companyProfile      CompanyProfile?
  companyActivities   CompanyActivity[]
  pushSubscriptions    PushSubscription[]
  conversationProjects ConversationProject[]
  hrcfoEmployee        HrcfoEmployee? @relation("EmployeeUser")
  managedHrcfoEmployees HrcfoEmployee[] @relation("EmployeeManager")
  cooComments          CooComment[]

  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model BillingPlan {
  id                String   @id
  name              String
  slug              String   @unique
  description       String
  priceUsd          Decimal  @db.Decimal(10, 2)
  dailyMessageLimit Int
  dailyTokenLimit   Int
  maxDocuments      Int      @default(0)
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  subscriptions     Subscription[]
  invoices          Invoice[]

  @@index([isActive, sortOrder])
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  planId             String
  status             SubscriptionStatus @default(PENDING_PAYMENT)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan               BillingPlan        @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments           Payment[]
  invoices           Invoice[]

  @@index([userId, status])
  @@index([planId])
  @@index([currentPeriodEnd])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  subscriptionId    String?
  provider          String        @default("MAISHAPAY")
  reference         String        @unique
  providerReference String?
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("USD")
  status            PaymentStatus @default(PENDING)
  checkoutPayload   Json?
  callbackPayload   Json?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice           Invoice?

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([providerReference])
}

model Invoice {
  id             String        @id @default(cuid())
  number         String        @unique
  userId         String
  planId         String?
  subscriptionId String?
  paymentId      String?       @unique
  planName       String
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("USD")
  status         InvoiceStatus @default(ISSUED)
  issuedAt       DateTime      @default(now())
  dueAt          DateTime?
  paidAt         DateTime?
  emailSentAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           BillingPlan?  @relation(fields: [planId], references: [id], onDelete: SetNull)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payment        Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  hrcfoTransactionId String?   @unique
  hrcfoTransaction   HrcfoExpense? @relation(fields: [hrcfoTransactionId], references: [id], onDelete: SetNull)

  @@index([userId, issuedAt])
  @@index([status, issuedAt])
}

model KnowledgeDocument {
  id            String         @id @default(cuid())
  userId        String
  title         String
  fileName      String
  mimeType      String
  sizeBytes     Int
  storageBucket String?
  storagePath   String?
  status        DocumentStatus @default(PROCESSING)
  extractedText String?
  errorMessage  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks        KnowledgeChunk[]

  @@index([userId, status, createdAt])
  @@index([storageBucket, storagePath])
  @@index([createdAt])
}

model KnowledgeChunk {
  id         String            @id @default(cuid())
  documentId String
  userId     String
  content    String
  tokenHint  Int               @default(0)
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime          @default(now())
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId, createdAt])
}

model CompanyProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  organizationName  String
  legalForm         String?
  sector            String?
  sizeRange         String?
  country           String?
  city              String?
  website           String?
  description       String?
  mission           String?
  productsServices  String?
  customers         String?
  markets           String?
  competitors       String?
  processes         String?
  tools             String?
  dataSystems       String?
  compliance        String?
  challenges        String?
  goals             String?
  kpis              String?
  userPosition      String?
  department        String?
  responsibilities  String?
  decisionRole      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sector])
  @@index([updatedAt])
}

model CompanyActivity {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  frequency   String?
  priority    String   @default("MEDIUM")
  tools       String?
  dataInputs  String?
  dataOutputs String?
  painPoints  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, priority, updatedAt])
}

model PendingRegistration {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  companyName  String?
  phone        String?
  role         UserRole @default(CLIENT)
  otpHash      String
  attempts     Int      @default(0)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email, expiresAt])
  @@index([expiresAt])
}

model Conversation {
  id        String     @id @default(cuid())
  userId    String
  title     String     @default("Nouvelle conversation")
  projectName String?
  projectId String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   ConversationProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages  Message[]
  usageLogs UsageLog[]

  @@index([userId, updatedAt])
  @@index([userId, projectName, updatedAt])
  @@index([userId, projectId, updatedAt])
}

model ConversationProject {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([userId, name])
  @@index([userId, updatedAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh     String
  auth       String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  userId         String?
  role           MessageRole
  content        String
  model          String?
  tokensUsed     Int?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([userId])
}

model UsageLog {
  id             String       @id @default(cuid())
  userId         String
  conversationId String?
  model          String
  inputTokens    Int          @default(0)
  outputTokens   Int          @default(0)
  totalTokens    Int          @default(0)
  estimatedCost  Decimal      @default(0) @db.Decimal(10, 6)
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([conversationId])
}

model Organization {
  id            String   @id @default(cuid())
  name          String
  sector        String?
  contactPerson String?
  email         String?
  phone         String?
  createdAt     DateTime @default(now())
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  companyName String?
  interest    String?
  source      String   @default("landing")
  consent     Boolean  @default(true)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
}

model ContactMessage {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  companyName String?
  subject     String
  message     String
  source      String   @default("landing")
  createdAt   DateTime @default(now())

  @@index([email, createdAt])
  @@index([source, createdAt])
}

model SupportTicket {
  id          String         @id @default(cuid())
  userId      String
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  resolution  String?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    TicketMessage[]

  @@index([userId, status])
  @@index([priority, createdAt])
}

model TicketMessage {
  id        String        @id @default(cuid())
  ticketId  String
  userId    String
  content   String
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([userId])
}

model SiteVisit {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@index([createdAt])
}

model PublicPublication {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  category    String   @default("RESSOURCE")
  excerpt     String
  content     String
  coverLabel  String?
  published   Boolean  @default(false)
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  comments    PublicPublicationComment[]
  reactions   PublicPublicationReaction[]

  @@index([category, published, createdAt])
  @@index([authorId])
}

model PublicPublicationComment {
  id            String   @id @default(cuid())
  publicationId String
  userId        String
  parentId      String?
  content       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  publication   PublicPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        PublicPublicationComment? @relation("PublicPublicationCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       PublicPublicationComment[] @relation("PublicPublicationCommentReplies")

  @@index([publicationId, createdAt])
  @@index([userId])
  @@index([parentId])
}

model PublicPublicationReaction {
  id            String   @id @default(cuid())
  publicationId String
  userId        String
  value         Int
  createdAt     DateTime @default(now())
  publication   PublicPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([publicationId, userId])
  @@index([userId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String    @default("INFO")
  targetUrl String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model Announcement {
  id        String                 @id @default(cuid())
  authorId  String
  title     String
  content   String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  author    User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  AnnouncementComment[]
  reactions AnnouncementReaction[]

  @@index([createdAt])
  @@index([authorId])
}

model AnnouncementComment {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  parentId       String?
  content        String
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent         AnnouncementComment? @relation("AnnouncementCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies        AnnouncementComment[] @relation("AnnouncementCommentReplies")

  @@index([announcementId, createdAt])
  @@index([userId])
  @@index([parentId])
}

model AnnouncementReaction {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  value          Int
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
}

model AppSetting {
  id                       String   @id @default("global")
  defaultDailyMessageLimit Int      @default(30)
  defaultDailyTokenLimit   Int      @default(100000)
  chatbotEnabled           Boolean  @default(true)
  maintenanceMode          Boolean  @default(false)
  supportAutoCloseDays     Int      @default(7)
  allowClientAnnouncements Boolean  @default(false)
  announcementEditWindowMinutes Int @default(30)
  commentEditWindowMinutes      Int @default(15)
  notificationRetentionDays     Int @default(60)
  signUpOtpEnabled              Boolean @default(true)
  signUpOtpExpirationMinutes    Int @default(10)
  adminRoleAccess               Json    @default("{}")
  updatedAt                DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entity, entityId])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  eventType   String
  status      String   @default("RECEIVED")
  payload     Json
  attempts    Int      @default(0)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([provider, eventType, createdAt])
  @@index([status, createdAt])
}

model ApiLog {
  id          String   @id @default(cuid())
  method      String
  path        String
  statusCode  Int
  userId      String?
  durationMs  Int?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([path, createdAt])
  @@index([statusCode, createdAt])
  @@index([userId, createdAt])
}

model HrcfoEmployee {
  id                  String   @id @default(cuid())
  userId              String?  @unique
  fullName            String
  email               String?
  department          String
  departmentId        String?
  jobTitle            String
  contractType        String   @default("PERMANENT")
  status              String   @default("ACTIVE")
  startDate           DateTime?
  monthlyCompensation Decimal? @db.Decimal(10, 2)
  managerName         String?
  managerUserId       String?
  skills              String?
  kpis                String?
  complianceStatus    String   @default("TO_REVIEW")
  notes               String?
  createdById         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User?    @relation("EmployeeUser", fields: [userId], references: [id], onDelete: SetNull)
  managerUser         User?    @relation("EmployeeManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  departmentRef       Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  payrolls            HrcfoPayroll[]

  @@index([status, department])
  @@index([userId])
  @@index([departmentId])
  @@index([managerUserId])
  @@index([createdAt])
}

model HrcfoBudget {
  id              String   @id @default(cuid())
  name            String
  ownerDepartment String
  departmentId    String?
  accountId       String?
  periodStart     DateTime?
  periodEnd       DateTime?
  amount          Decimal  @db.Decimal(12, 2)
  spentAmount     Decimal  @default(0) @db.Decimal(12, 2)
  status          String   @default("OPEN")
  riskLevel       String   @default("LOW")
  notes           String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  department      Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  account         FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  transactions    HrcfoExpense[]
  payrolls        HrcfoPayroll[]

  @@index([status, ownerDepartment])
  @@index([departmentId])
  @@index([accountId])
  @@index([createdAt])
}

model HrcfoExpense {
  id          String   @id @default(cuid())
  title       String
  requesterName String
  category    String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  project     String?
  transactionType String @default("MANUAL")
  transactionCategory String @default("OUT")
  transactionDate DateTime @default(now())
  accountId   String?
  departmentId String?
  budgetId    String?
  paymentMethod String?
  attachmentUrl String?
  sourceType  String?
  sourceId    String?
  clientUserId String?
  status      String   @default("SUBMITTED")
  priority    String   @default("MEDIUM")
  evidenceUrl String?
  dueDate     DateTime?
  paidAt      DateTime?
  validatedAt DateTime?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  account     FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  budget      HrcfoBudget? @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  invoice     Invoice?
  payroll     HrcfoPayroll?

  @@index([status, priority])
  @@index([transactionCategory, status, transactionDate])
  @@index([accountId, transactionDate])
  @@index([departmentId, transactionDate])
  @@index([budgetId, transactionDate])
  @@index([sourceType, sourceId])
  @@index([createdAt])
}

model HrcfoInvoice {
  id             String   @id @default(cuid())
  invoiceNumber  String
  counterparty   String
  invoiceType    String   @default("PAYABLE")
  amount         Decimal  @db.Decimal(12, 2)
  currency       String   @default("USD")
  dueDate        DateTime?
  status         String   @default("PENDING")
  relatedProject String?
  notes          String?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, dueDate])
  @@index([invoiceType, createdAt])
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employees   HrcfoEmployee[]
  budgets     HrcfoBudget[]
  transactions HrcfoExpense[]

  @@index([status, name])
}

model FinancialAccount {
  id             String   @id @default(cuid())
  name           String   @unique
  accountType    String   @default("CASH")
  description    String?
  openingBalance Decimal  @default(0) @db.Decimal(12, 2)
  currentBalance Decimal  @default(0) @db.Decimal(12, 2)
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  budgets        HrcfoBudget[]
  transactions   HrcfoExpense[]
  payrolls       HrcfoPayroll[]

  @@index([status, accountType])
}

model HrcfoPayroll {
  id              String   @id @default(cuid())
  employeeId      String
  periodStart     DateTime
  periodEnd       DateTime
  grossAmount     Decimal  @db.Decimal(12, 2)
  bonusAmount     Decimal  @default(0) @db.Decimal(12, 2)
  deductionAmount Decimal  @default(0) @db.Decimal(12, 2)
  netAmount       Decimal  @db.Decimal(12, 2)
  accountId       String?
  budgetId        String?
  transactionId   String?  @unique
  status          String   @default("DRAFT")
  notes           String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  employee        HrcfoEmployee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  account         FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  budget          HrcfoBudget? @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  transaction     HrcfoExpense? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@unique([employeeId, periodStart, periodEnd])
  @@index([status, periodStart])
  @@index([accountId])
  @@index([budgetId])
}

model ScoVendor {
  id              String   @id @default(cuid())
  name            String
  category        String
  contactName     String?
  email           String?
  phone           String?
  paymentTerms    String?
  reliabilityScore Int     @default(70)
  avgLeadTimeDays Int      @default(7)
  status          String   @default("ACTIVE")
  notes           String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, category])
  @@index([createdAt])
}

model ScoPurchaseRequest {
  id                 String   @id @default(cuid())
  title              String
  requesterName      String
  justification      String
  project            String?
  urgency            String   @default("MEDIUM")
  estimatedAmount    Decimal? @db.Decimal(12, 2)
  currency           String   @default("USD")
  status             String   @default("DRAFT")
  budgetStatus       String   @default("PENDING_REVIEW")
  selectedVendorName String?
  neededBy           DateTime?
  notes              String?
  createdById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status, urgency])
  @@index([createdAt])
}

model ScoInventoryItem {
  id              String   @id @default(cuid())
  materialItemId  String?
  name            String
  sku             String?
  category        String
  quantity        Int      @default(0)
  minimumQuantity Int      @default(1)
  unit            String   @default("unité")
  location        String?
  ownerName       String?
  status          String   @default("AVAILABLE")
  lastInventoryAt DateTime?
  notes           String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  materialItem     MaterialItem? @relation(fields: [materialItemId], references: [id], onDelete: SetNull)

  @@index([status, category])
  @@index([materialItemId])
  @@index([quantity])
}

model ScoAsset {
  id              String   @id @default(cuid())
  materialItemId  String?
  tag             String
  name            String
  category        String
  assignedTo      String?
  condition       String   @default("GOOD")
  status          String   @default("ASSIGNED")
  purchaseDate    DateTime?
  maintenanceDueAt DateTime?
  notes           String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  materialItem     MaterialItem? @relation(fields: [materialItemId], references: [id], onDelete: SetNull)

  @@index([status, condition])
  @@index([materialItemId])
  @@index([tag])
}

model ScoLogisticsEvent {
  id                 String   @id @default(cuid())
  title              String
  location           String
  eventDate          DateTime?
  ownerName          String
  status             String   @default("PLANNED")
  transportPlan      String?
  equipmentChecklist String?
  riskNotes          String?
  notes              String?
  createdById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status, eventDate])
  @@index([createdAt])
}

model MaterialItem {
  id          String   @id @default(cuid())
  name        String
  sku         String?  @unique
  category    String
  itemType    String   @default("EQUIPMENT")
  unit        String   @default("unité")
  description String?
  status      String   @default("ACTIVE")
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  inventoryItems ScoInventoryItem[]
  assets      ScoAsset[]

  @@index([status, category])
  @@index([itemType, status])
}

model CooOperation {
  id                   String   @id @default(cuid())
  title                String
  description          String?
  pilotDepartmentId    String?
  pilotDepartmentName  String?
  involvedDepartments  String?
  leadEmployeeId       String?
  leadEmployeeName     String?
  collaborators        String?
  priority             String   @default("NORMAL")
  status               String   @default("PLANNED")
  startDate            DateTime?
  dueDate              DateTime?
  progress             Int      @default(0)
  objectives           String?
  deliverables         String?
  comments             String?
  attachmentUrl        String?
  createdById          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tasks                CooTask[]
  departmentRequests   CooDepartmentRequest[]
  blockers             CooBlocker[]
  reports              CooOperationalReport[]

  @@index([status, priority])
  @@index([pilotDepartmentId])
  @@index([leadEmployeeId])
  @@index([dueDate])
}

model CooTask {
  id                    String   @id @default(cuid())
  title                 String
  description           String?
  taskType              String   @default("ADMINISTRATIVE")
  operationId           String?
  departmentId          String?
  departmentName        String?
  responsibleEmployeeId String?
  responsibleName       String?
  assigneeEmployeeId    String?
  assigneeName          String?
  plannedDate           DateTime?
  plannedStartTime      String?
  deadlineTime          String?
  priority              String   @default("NORMAL")
  status                String   @default("TODO")
  progress              Int      @default(0)
  managerComment        String?
  assigneeComment       String?
  proofUrl              String?
  lateReason            String?
  blockerReason         String?
  closedAt              DateTime?
  createdById           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  operation             CooOperation? @relation(fields: [operationId], references: [id], onDelete: SetNull)
  blockers              CooBlocker[]

  @@index([status, priority])
  @@index([plannedDate])
  @@index([departmentId])
  @@index([responsibleEmployeeId])
  @@index([assigneeEmployeeId])
  @@index([operationId])
}

model CooRecurringTask {
  id                    String   @id @default(cuid())
  title                 String
  frequency             String   @default("DAILY")
  daysOfWeek            String?
  startDate             DateTime?
  endDate               DateTime?
  deadlineTime          String?
  departmentId          String?
  departmentName        String?
  responsibleEmployeeId String?
  responsibleName       String?
  assigneeEmployeeId    String?
  assigneeName          String?
  taskTemplate          String
  status                String   @default("ACTIVE")
  createdById           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status, frequency])
  @@index([departmentId])
}

model CooDepartmentRequest {
  id                          String   @id @default(cuid())
  requesterDepartmentId       String?
  requesterDepartmentName     String?
  targetDepartmentId          String?
  targetDepartmentName        String?
  subject                     String
  description                 String?
  requesterEmployeeId         String?
  requesterName               String?
  targetResponsibleEmployeeId String?
  targetResponsibleName       String?
  priority                    String   @default("NORMAL")
  status                      String   @default("NEW")
  requestedAt                 DateTime?
  dueDate                     DateTime?
  expectedResponse            String?
  comment                     String?
  taskId                      String?
  operationId                 String?
  createdById                 String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  operation                   CooOperation? @relation(fields: [operationId], references: [id], onDelete: SetNull)

  @@index([status, priority])
  @@index([requesterDepartmentId])
  @@index([targetDepartmentId])
  @@index([operationId])
}

model CooBlocker {
  id                    String   @id @default(cuid())
  title                 String
  description           String?
  sourceType            String   @default("TASK")
  taskId                String?
  operationId           String?
  departmentId          String?
  departmentName        String?
  responsibleEmployeeId String?
  responsibleName       String?
  severity              String   @default("MEDIUM")
  impact                String?
  correctiveAction      String?
  status                String   @default("OPEN")
  declaredAt            DateTime?
  resolvedAt            DateTime?
  resolutionComment     String?
  createdById           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  task                  CooTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  operation             CooOperation? @relation(fields: [operationId], references: [id], onDelete: SetNull)

  @@index([status, severity])
  @@index([departmentId])
  @@index([taskId])
  @@index([operationId])
}

model CooMeeting {
  id                    String   @id @default(cuid())
  title                 String
  meetingType           String   @default("COORDINATION")
  meetingDate           DateTime?
  meetingTime           String?
  departmentId          String?
  departmentName        String?
  participants          String?
  agenda                String?
  decisions             String?
  generatedTasks        String?
  reportOwnerEmployeeId String?
  reportOwnerName       String?
  status                String   @default("PLANNED")
  minutes               String?
  attachmentUrl         String?
  createdById           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status, meetingDate])
  @@index([departmentId])
}

model CooWorkflow {
  id             String   @id @default(cuid())
  name           String
  description    String?
  departmentId   String?
  departmentName String?
  steps          String
  stepOwners     String?
  stepDeadlines  String?
  status         String   @default("DRAFT")
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  shares         CooWorkflowShare[]

  @@index([status, departmentId])
}

model CooOperationalReport {
  id              String   @id @default(cuid())
  title           String
  reportType      String   @default("DAILY")
  periodStart     DateTime?
  periodEnd       DateTime?
  departmentId    String?
  departmentName  String?
  employeeId      String?
  employeeName    String?
  recipientEmployeeId String?
  recipientName   String?
  operationId     String?
  priority        String   @default("NORMAL")
  content         String?
  readAt          DateTime?
  treatedAt       DateTime?
  tasksCreated    Int      @default(0)
  tasksCompleted  Int      @default(0)
  tasksValidated  Int      @default(0)
  tasksRejected   Int      @default(0)
  lateTasks       Int      @default(0)
  blockersCount   Int      @default(0)
  executionRate   Decimal  @default(0) @db.Decimal(5, 2)
  mainBlockers    String?
  recommendations String?
  status          String   @default("DRAFT")
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  operation       CooOperation? @relation(fields: [operationId], references: [id], onDelete: SetNull)

  @@index([reportType, status])
  @@index([departmentId])
  @@index([employeeId])
  @@index([recipientEmployeeId])
  @@index([operationId])
}

model CooComment {
  id                  String   @id @default(cuid())
  entityType          String
  entityId            String
  authorId            String
  content             String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  author              User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId, createdAt])
  @@index([authorId])
}

model CooWorkflowShare {
  id                 String    @id @default(cuid())
  workflowId         String
  employeeId         String
  employeeName       String
  userId             String?
  instruction        String?
  readAt             DateTime?
  createdById        String?
  createdAt          DateTime  @default(now())
  workflow           CooWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, employeeId])
  @@index([employeeId])
  @@index([userId])
}
